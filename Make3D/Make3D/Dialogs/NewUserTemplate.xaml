<Window
    x:Class="Barnacle.Dialogs.NewUserTemplate"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Barnacle.Dialogs"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Save Project As Template"
    Width="800"
    Height="550"
    Background="{StaticResource WindowBackBrush}"
    mc:Ignorable="d">
    <Grid Margin="2,4,2,4">
        <Grid.Background>
            <ImageBrush ImageSource="/Barnacle;component/Images/Barnicle.png" />
        </Grid.Background>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*" />
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="1*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="50" />
            <RowDefinition Height="50" />
            <RowDefinition Height="10" />
            <RowDefinition Height="50" />
            <RowDefinition Height="30" />
            <RowDefinition Height="45" />
            <RowDefinition />
            <RowDefinition Height="50" />
            <RowDefinition Height="50" />
        </Grid.RowDefinitions>
        <Border
            Grid.Row="1"
            Grid.RowSpan="1"
            Grid.Column="1"
            Grid.ColumnSpan="4"
            Background="White"
            BorderThickness="4"
            Style="{StaticResource ControlBorder}">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*" />
                    <ColumnDefinition Width="2*" />
                </Grid.ColumnDefinitions>

                <Label
                    Grid.Column="0"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center"
                    FontSize="18">
                    New Template Name
                </Label>

                <TextBox
                    Grid.Column="1"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Center"
                    FontSize="18"
                    Text="{Binding TemplateName}" />
            </Grid>
        </Border>

        <Border
            Grid.Row="3"
            Grid.RowSpan="4"
            Grid.Column="1"
            Grid.ColumnSpan="4"
            Background="White"
            BorderThickness="4"
            Style="{StaticResource ControlBorder}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="40" />
                    <RowDefinition />
                </Grid.RowDefinitions>
                <Label
                    Grid.Row="0"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    FontSize="18">
                    Description
                </Label>

                <TextBox
                    x:Name="DescriptionBox"
                    Grid.Row="1"
                    HorizontalAlignment="Stretch"
                    VerticalContentAlignment="Top"
                    AcceptsReturn="True"
                    BorderThickness="4"
                    FontSize="18"
                    IsReadOnly="True"
                    Text="{Binding TemplateDescription}"
                    VerticalScrollBarVisibility="Visible" />
            </Grid>
        </Border>
        <Border
      Grid.Row="7"
      Grid.RowSpan="1"
      Grid.Column="1"
      Grid.ColumnSpan="4"
      Background="White"
      BorderThickness="4"
      Style="{StaticResource ControlBorder}">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*" />
                    <ColumnDefinition Width="1*" />
                </Grid.ColumnDefinitions>

                <CheckBox Content="Include File Contents" IsChecked="{Binding IncludeFileContents}" FontSize="18" VerticalAlignment="Top" Grid.Column="0" ToolTip="Model files,scripts etc will all be included in the template." />
            </Grid>
        </Border>
        <Grid
            Grid.Row="8"
            Grid.Column="2"
            Grid.ColumnSpan="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*" />
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>
            <Button
                Grid.Column="0"
                Margin="4,0,4,0"
                Click="Cancel_Click"
                Content="Cancel" />

            <Button
                x:Name="OK_Button"
                Grid.Column="1"
                Margin="4,0,4,0"
                Click="OK_Click"
                Content="OK"
                IsDefault="True" />
        </Grid>
    </Grid>
</Window>