<Window
    x:Class="Barnacle.Dialogs.NewProjectDlg"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Barnacle.Dialogs"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="New Project"
    Width="800"
    Height="600"
    Background="{StaticResource WindowBackBrush}"
    Loaded="Window_Loaded"
    mc:Ignorable="d">

    <Grid Margin="2,4,2,4">
        <Grid.Background>
            <ImageBrush ImageSource="/Barnacle;component/Images/Barnicle.png" />
        </Grid.Background>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*" />
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="1*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="50" />
            <RowDefinition Height="50" />
            <RowDefinition Height="10" />
            <RowDefinition Height="50" />
            <RowDefinition Height="30" />
            <RowDefinition Height="45" />
            <RowDefinition />
            <RowDefinition Height="50" />
        </Grid.RowDefinitions>

        <Border
        Grid.Row="1"
        Grid.RowSpan="1"
        Grid.Column="1"
        Grid.ColumnSpan="4"
        Background="White"
        BorderThickness="4"
        Style="{StaticResource ControlBorder}">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*" />
                    <ColumnDefinition Width="2*" />
                </Grid.ColumnDefinitions>

                <Label
                Grid.Column="0"
                HorizontalAlignment="Left"
                VerticalAlignment="Center"
                FontSize="18">
                    Project Name
                </Label>

                <TextBox
                Grid.Column="1"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Center"
                FontSize="18"
                TextChanged="TextBox_TextChanged" />
            </Grid>
        </Border>

        <Border
        Grid.Row="3"
        Grid.RowSpan="1"
        Grid.Column="1"
        Grid.ColumnSpan="4"
        Background="White"
        BorderThickness="4"
        Style="{StaticResource ControlBorder}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*" />
                    <ColumnDefinition Width="1*" />
                    <ColumnDefinition Width="1*" />
                </Grid.ColumnDefinitions>
                <Label
                Grid.Column="0"
                VerticalAlignment="Center"
                FontSize="18">
                    Template
                </Label>

                <ComboBox
                 x:Name="TemplateBox"
                Grid.Column="1"
                Grid.ColumnSpan="1"
                 SelectionChanged="ComboBox_SelectionChanged" />
            </Grid>
        </Border>

        <Border
        Grid.Row="5"
        Grid.RowSpan="2"
        Grid.Column="1"
        Grid.ColumnSpan="4"
        Background="White"
        BorderThickness="4"
        Style="{StaticResource ControlBorder}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="40" />
                    <RowDefinition />
                </Grid.RowDefinitions>
                <Label
                Grid.Row="0"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                FontSize="18">
                    Description
                </Label>

                <TextBox
               x:Name="DescriptionBox"
                Grid.Row="1"
                HorizontalAlignment="Stretch"
                AcceptsReturn="True"
                FontSize="18"
                IsReadOnly="True"

                VerticalScrollBarVisibility="Visible" />
            </Grid>
        </Border>

        <Grid
        Grid.Row="7"
        Grid.Column="1"
        Grid.ColumnSpan="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="2*" />
            </Grid.ColumnDefinitions>
            <Button
            Grid.Column="1"
            Click="Cancel_Click"
            Content="Cancel">
                <Button.Style>
                    <Style BasedOn="{StaticResource LargeButton}" TargetType="Button">

                        <Style.Triggers>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Margin" Value="4,4,4,4" />
                                <Setter Property="FontSize" Value="20" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>

            <Button
            x:Name="OK_Button"
            Grid.Column="3"
            HorizontalAlignment="Right"
            Click="OK_Click"
            Content="Ok"
            IsDefault="True"
            IsEnabled="{Binding OKEnabled}">

                <Button.Style>
                    <Style BasedOn="{StaticResource LargeButton}" TargetType="Button">

                        <Style.Triggers>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Margin" Value="4,4,4,4" />
                                <Setter Property="FontSize" Value="20" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </Grid>
    </Grid>
</Window>